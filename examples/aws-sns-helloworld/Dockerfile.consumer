# Build context MUST be the repo root (this example imports sibling modules):
#   docker build -f examples/aws-sns-helloworld/Dockerfile.consumer -t aws-sns-helloworld-consumer .

FROM golang:1.24 AS build
WORKDIR /src
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=arm64 go build -o /out/bootstrap ./examples/aws-sns-helloworld/consumer

FROM public.ecr.aws/lambda/provided:al2023
COPY --from=build /out/bootstrap ${LAMBDA_TASK_ROOT}/bootstrap
CMD [ "bootstrap" ]
